# Appwrite Cloud Configuration
# Create a project at https://cloud.appwrite.io
# Use Singapore region where available

VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here

# Appwrite Database ID (create in Appwrite console)
VITE_APPWRITE_DATABASE_ID=your_database_id_here

# Appwrite Storage Bucket ID (for reading attachments if needed)
VITE_APPWRITE_STORAGE_BUCKET_ID=your_bucket_id_here

# Appwrite Function IDs (create these functions in Appwrite console)
VITE_APPWRITE_FN_GET_QUESTIONS=your_function_id_here
VITE_APPWRITE_FN_SUBMIT_QUESTION=your_function_id_here
VITE_APPWRITE_FN_TOGGLE_VOTE=your_function_id_here
VITE_APPWRITE_FN_TEACHER_PROGRESS=your_function_id_here
